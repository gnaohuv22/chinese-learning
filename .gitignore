# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Angular
/.angular/cache

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code (track shared config; ignore local overrides)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json
.history/

# Testing & coverage
/coverage
/libpeerconnection.log
testem.log
/typings
__screenshots__/

# Playwright / browser MCP debug dumps (not source)
.playwright-mcp/

# Firebase local
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# Deployment (local link state)
.vercel/

# Environment & secrets (never commit)
.env
.env.*
!.env.example
*.pem
**/serviceAccount*.json
**/google-services.json
GoogleService-Info.plist

# Logs
*.log

# Sass
.sass-cache/
/connect.lock

# OS
.DS_Store
Thumbs.db

# Root-level screenshots and one-off captures (keep code under src/)
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
gen-lang-client-0110680886-42b1531ba924.json
package-lock.json
